---
import { Image } from 'astro:assets';
import { resolveMedia } from '../lib/media';

interface Props {
	src?: string;
	alt: string;
	class?: string;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	priority?: boolean;
}

const { src, alt, class: className = '', loading, fetchpriority, priority } = Astro.props;
const image = resolveMedia(src);
const imgLoading = priority ? 'eager' : (loading ?? 'lazy');
const imgFetchPriority = priority ? 'high' : fetchpriority;
---

{
	image ? (
		<Image
			src={image}
			alt={alt}
			class={className}
			loading={imgLoading}
			fetchpriority={imgFetchPriority}
			sizes="(max-width: 768px) 100vw, 50vw"
		/>
	) : (
		<div class:list={['flex items-center justify-center bg-sand/50 text-ink/40', className]}>
			<span class="text-sm">Photo à venir</span>
		</div>
	)
}
