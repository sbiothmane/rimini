---
import type { CollectionEntry } from 'astro:content';
import MediaImage from './MediaImage.astro';
import type { Locale } from '../config/site';
import { localePath } from '../config/site';
import { productSlug } from '../utils/content';

interface Props {
	product: CollectionEntry<'products'>;
	locale: Locale;
}

const { product, locale } = Astro.props;
const slug = productSlug(product.id);
const href = localePath(locale, `/collection/${slug}/`);
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-sand bg-cream shadow-sm transition hover:shadow-md">
	<a href={href} class="block aspect-[4/5] overflow-hidden bg-sand/30">
		<MediaImage
			src={product.data.thumbnail}
			alt={product.data.title}
			class="h-full w-full object-cover transition group-hover:scale-[1.02]"
		/>
	</a>
	<div class="flex flex-1 flex-col gap-2 p-4">
		<h2 class="text-lg font-semibold">
			<a href={href} class="hover:text-clay">
				{product.data.title}
			</a>
		</h2>
		<p class="line-clamp-2 text-sm text-ink/70">{product.data.description}</p>
		{
			product.data.priceFrom && (
				<p class="mt-auto text-sm font-medium text-clay">
					À partir de {product.data.priceFrom} {product.data.currency}
				</p>
			)
		}
	</div>
</article>
