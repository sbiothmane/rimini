---
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, site, type Locale } from '../../../config/site';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
const telHref = `tel:+${site.whatsapp}`;
---

<BaseLayout locale={locale} title={t.contact.title} description={t.contact.subtitle}>
	<div class="mx-auto max-w-2xl px-4 py-12 sm:px-6">
		<h1 class="text-3xl font-bold">{t.contact.title}</h1>
		<p class="mt-4 text-lg text-ink/75">{t.contact.subtitle}</p>
		<dl class="mt-10 space-y-4 rounded-2xl border border-sand bg-sand/30 p-6 text-sm">
			<div>
				<dt class="font-semibold text-clay">{t.contact.hours}</dt>
				<dd class="mt-1 text-ink/70">{t.contact.hours}</dd>
			</div>
			<div>
				<dt class="font-semibold text-clay">{t.contact.location}</dt>
				<dd class="mt-1 text-ink/70">{site.city || t.contact.location}</dd>
			</div>
		</dl>
		<div class="mt-8 flex flex-wrap gap-4">
			<WhatsAppButton label={t.cta.whatsapp} />
			<a
				href={telHref}
				class="inline-flex items-center justify-center rounded-full border border-clay px-6 py-3 text-sm font-semibold text-clay transition hover:bg-clay hover:text-cream"
			>
				{t.cta.call}
			</a>
		</div>
	</div>
</BaseLayout>
