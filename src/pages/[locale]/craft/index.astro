---
import { render } from 'astro:content';
import craftVideo from '../../../assets/media/videos/craft/atelier-process-0252.mp4';
import craftPoster from '../../../assets/media/videos/craft/atelier-process-0252-poster.webp';
import MediaImage from '../../../components/MediaImage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, type Locale } from '../../../config/site';
import { useTranslations } from '../../../i18n/ui';
import { getCraftSteps } from '../../../utils/content';

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
const steps = await getCraftSteps();
const stepsRendered = await Promise.all(
	steps.map(async (step) => ({ step, ...(await render(step)) })),
);
---

<BaseLayout locale={locale} title={t.craft.title} description={t.craft.subtitle}>
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
		<header class="mb-12 max-w-2xl">
			<h1 class="text-3xl font-bold">{t.craft.title}</h1>
			<p class="mt-3 text-ink/70">{t.craft.subtitle}</p>
		</header>
		<div class="mb-12 overflow-hidden rounded-3xl border border-sand bg-ink">
			<video
				class="aspect-video w-full object-cover"
				controls
				playsinline
				preload="metadata"
				poster={craftPoster.src}
			>
				<source src={craftVideo} type="video/mp4" />
			</video>
		</div>

		<ol class="grid gap-8 md:grid-cols-3">
			{
				stepsRendered.map(({ step, Content }, index) => (
					<li class="flex flex-col gap-4 overflow-hidden rounded-2xl border border-sand bg-cream">
						{
							step.data.image && (
								<MediaImage
									src={step.data.image}
									alt={step.data.title}
									class="aspect-[4/3] w-full object-cover"
								/>
							)
						}
						<div class="flex flex-col gap-4 p-6">
						<span class="flex h-10 w-10 items-center justify-center rounded-full bg-clay text-sm font-bold text-cream">
							{index + 1}
						</span>
						<h2 class="text-xl font-semibold">{step.data.title}</h2>
						<p class="text-sm text-ink/70">{step.data.description}</p>
						<div class="prose prose-sm text-ink/70">
							<Content />
						</div>
						</div>
					</li>
				))
			}
		</ol>
	</div>
</BaseLayout>
