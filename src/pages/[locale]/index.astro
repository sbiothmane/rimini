---
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import ProductCard from '../../components/ProductCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, localePath, type Locale } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import { getProducts } from '../../utils/content';

export function getStaticPaths() {
	return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
const products = await getProducts(locale);
const featured = products.filter((p) => p.data.featured).slice(0, 3);
const display = featured.length > 0 ? featured : products.slice(0, 3);
---

<BaseLayout locale={locale} title={t.nav.home} description={t.home.subtitle}>
	<section class="relative overflow-hidden border-b border-sand">
		<div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:py-24">
			<div class="flex flex-col gap-6">
				<p class="text-xs font-semibold uppercase tracking-widest text-clay">{t.home.eyebrow}</p>
				<h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl">{t.home.title}</h1>
				<p class="max-w-lg text-lg text-ink/75">{t.home.subtitle}</p>
				<ul class="flex flex-col gap-2 text-sm text-ink/70">
					<li>✓ {t.home.trust1}</li>
					<li>✓ {t.home.trust2}</li>
					<li>✓ {t.home.trust3}</li>
				</ul>
				<div class="flex flex-wrap gap-3 pt-2">
					<WhatsAppButton label={t.cta.whatsapp} />
					<a
						href={localePath(locale, '/collection/')}
						class="inline-flex items-center justify-center rounded-full border border-clay px-6 py-3 text-sm font-semibold text-clay transition hover:bg-clay hover:text-cream"
					>
						{t.cta.viewCollection}
					</a>
				</div>
			</div>
			<div
				class="aspect-[4/5] rounded-3xl bg-gradient-to-br from-sand via-cream to-clay/30 shadow-inner"
				role="img"
				aria-label="Hero — ajoutez une photo d'atelier ou de chaussure"
			>
			</div>
		</div>
	</section>

	{
		display.length > 0 && (
			<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
				<div class="mb-8 flex items-end justify-between gap-4">
					<h2 class="text-2xl font-bold">{t.collection.title}</h2>
					<a href={localePath(locale, '/collection/')} class="text-sm font-medium text-clay hover:underline">
						{t.cta.viewCollection} →
					</a>
				</div>
				<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{display.map((product) => (
						<ProductCard product={product} locale={locale} />
					))}
				</div>
			</section>
		)
	}

	<section class="border-t border-sand bg-sand/30">
		<div class="mx-auto max-w-6xl px-4 py-16 text-center sm:px-6">
			<h2 class="text-2xl font-bold">{t.craft.title}</h2>
			<p class="mx-auto mt-3 max-w-xl text-ink/70">{t.craft.subtitle}</p>
			<a
				href={localePath(locale, '/craft/')}
				class="mt-6 inline-block text-sm font-semibold text-clay hover:underline"
			>
				{t.home.craftTeaser} →
			</a>
		</div>
	</section>
</BaseLayout>
